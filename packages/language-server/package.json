        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.11",
        "vscode-uri": "^3.0.8"
    },
    "devDependencies": {
        "@types/node": "^16.18.34",
        "typescript": "^5.1.3"
    },
    "keywords": [
        "django",
        "cotton",
        "language-server",
        "lsp",
        "html",
        "templates"
    ]
}
